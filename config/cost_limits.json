{
  "schema_version": "1.0",
  "description": "Cost limits configuration for DIL Ebook Agent MVP",
  "limits": {
    "max_tokens_per_run": 100000,
    "max_cost_per_run": 0.50,
    "max_requests_per_agent": 20,
    "max_chapters_per_run": 10
